# Telegram API credentials (from https://my.telegram.org)
API_ID=
API_HASH=

# Telegram phone number (with country code, e.g. +989123456789)
PHONE=

# Telegram session string (auto-generated on first run via login.js)
SESSION=

# Allowed Telegram user IDs (comma-separated)
# Only these users can trigger file downloads
ALLOWED_USERS=

# Allowed Chat IDs (comma-separated, optional)
# If set, bot only responds to files sent in these specific chats
# Leave empty to allow all chats where ALLOWED_USERS send files
# Use /chatid command in any chat to get its ID
ALLOWED_CHATS=

# Main domain
DOMAIN=yourdomain.com

# Subdomains
FILES_SUBDOMAIN=files

# Express port (default: 3000)
PORT=3000

# Upload directory
UPLOAD_DIR=./uploads

# SSL certificate paths
SSL_CERT=
SSL_KEY=
SSL_FULLCHAIN=
