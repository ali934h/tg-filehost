# Telegram bot token from @BotFather. The bot uses GramJS to talk MTProto
# directly, so it can upload/download files up to 2 GB straight to your chat
# (well above the 50 MB Bot-API HTTP limit).
BOT_TOKEN=

# Telegram client app credentials from https://my.telegram.org/apps.
# These identify the *client app* (this bot process). Required so GramJS can
# speak MTProto.
TG_API_ID=
TG_API_HASH=

# Path where the persisted MTProto session is stored.
# Created/updated automatically; chmod 600.
TG_SESSION_FILE=/root/tg-filehost/telegram.session

# Comma-separated Telegram user IDs allowed to use the bot.
# Empty = open to everyone (NOT recommended in production).
ALLOWED_USERS=

# Public host that points to this server (no scheme, no trailing slash).
# Used to build file URLs: https://<HOST>/files/<filename>
# Example: files.example.com
HOST=

# Internal HTTP port (Node listens on 127.0.0.1 only; nginx terminates TLS).
PORT=3000

# Where uploaded files are stored on disk and served from by nginx.
# Default lives outside /root so nginx (www-data) can serve it without
# loosening permissions on your home directory.
UPLOAD_DIR=/var/lib/tg-filehost/files

# Per-job staging area for files downloaded from external URLs before they
# are forwarded to the Telegram chat. Cleaned up automatically.
TEMP_DIR=/var/lib/tg-filehost/temp

# Maximum allowed file size for *uploads from Telegram*, in megabytes.
# Telegram's hard cap is 2048 (2 GB).
MAX_FILE_MB=2048

# Maximum allowed file size for *downloads from external URLs* before they
# are forwarded to the Telegram chat, in megabytes.
MAX_DOWNLOAD_MB=2048

# How many days hosted files are kept on disk before being garbage collected.
# 0 = keep forever.
RETENTION_DAYS=0

# How often the retention sweep runs (milliseconds). Default: every hour.
RETENTION_INTERVAL_MS=3600000

# Logging verbosity: error | warn | info | debug
LOG_LEVEL=info

# Production / development.
NODE_ENV=production
