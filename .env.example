# Telegram Bot Token
BOT_TOKEN=

# Allowed Telegram user IDs (comma-separated)
ALLOWED_USERS=

# Main domain
DOMAIN=yourdomain.com

# Subdomains
FILES_SUBDOMAIN=files
BOT_SUBDOMAIN=bot

# Express port (default: 3000)
PORT=3000

# Upload directory
UPLOAD_DIR=./uploads

# SSL Certificate paths
SSL_CERT_PATH=
SSL_KEY_PATH=
