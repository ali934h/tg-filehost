# Telegram MTProto credentials — get from https://my.telegram.org
API_ID=
API_HASH=
PHONE=

# GramJS string session (filled automatically by setup.sh via src/login.js)
SESSION=

# Comma-separated Telegram user IDs allowed to use the bot
ALLOWED_USERS=

# Comma-separated Telegram chat/channel IDs allowed (overrides ALLOWED_USERS if set)
ALLOWED_CHATS=

# Full host (domain or subdomain) that points to this server
# Example: tg-filehost.example.com  or  files.example.com
# This is used to build file download URLs: https://<HOST>/files/<filename>
HOST=

# Internal port — Node.js listens on 127.0.0.1 only.
# nginx handles SSL on 443 and proxies to this port.
# Avoid: 80, 443, 1080, 2053, 2083, 8080 (used by nginx / 3x-ui / common proxies)
PORT=3000

# Directory where uploaded files are stored on disk
UPLOAD_DIR=/root/tg-filehost-downloads

# SSL certificate paths (Cloudflare Origin CA or any valid cert)
SSL_CERT=
SSL_KEY=
SSL_FULLCHAIN=
