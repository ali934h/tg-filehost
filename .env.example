# Telegram MTProto credentials — get from https://my.telegram.org
API_ID=
API_HASH=
PHONE=

# GramJS string session — written automatically by `node setup.js`.
# Treat as a secret: it grants full access to the logged-in account.
SESSION=

# Comma-separated Telegram user IDs allowed to use the bot.
# Required if ALLOWED_CHATS is empty.
ALLOWED_USERS=

# Comma-separated chat/channel IDs allowed.
# If set, ALLOWED_CHATS takes precedence over ALLOWED_USERS.
ALLOWED_CHATS=

# Public host that points to this server (no scheme, no trailing slash).
# Used to build file URLs: https://<HOST>/files/<filename>
# Example: files.example.com
HOST=

# Internal port — Node.js listens on 127.0.0.1 only.
# nginx terminates TLS on 443 and proxies /health to this port.
PORT=3000

# Where uploaded files are stored on disk.
# Default lives outside /root so nginx (www-data) can serve it without
# loosening permissions on your home directory.
UPLOAD_DIR=/var/lib/tg-filehost/files

# Maximum allowed file size in MB. Telegram's hard cap is 2048 (2 GB).
MAX_FILE_MB=2048

# Logging verbosity: error | warn | info | debug
LOG_LEVEL=info
