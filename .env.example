# Telegram API credentials (from https://my.telegram.org)
API_ID=
API_HASH=

# Telegram phone number (with country code, e.g. +989123456789)
PHONE=

# Telegram session string (auto-generated on first run)
SESSION=

# Allowed Telegram user IDs (comma-separated)
ALLOWED_USERS=

# Main domain
DOMAIN=yourdomain.com

# Subdomains
FILES_SUBDOMAIN=files

# Express port (default: 3000)
PORT=3000

# Upload directory
UPLOAD_DIR=./uploads

# SSL certificate directory (must contain cert.crt and private.key)
SSL_DIR=
